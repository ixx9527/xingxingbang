# 星星榜 - 环境变量配置
# 请复制此文件为 .env 并修改 SECRET_KEY

# 必须修改！生成方法：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# 数据库（SQLite 路径）
DATABASE_URL=sqlite:///./data/xingxingbang.db

# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 服务配置
APP_NAME=星星榜
APP_VERSION=1.0.0