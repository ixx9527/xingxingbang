/* pages/stats/stats.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* 孩子选择 */
.child-picker {
  margin-bottom: 20rpx;
}

.picker-view {
  display: inline-flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 30rpx;
  border-radius: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.arrow {
  margin-left: 10rpx;
  color: #999;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  text-align: center;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: block;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-top: 10rpx;
}

.stat-value.plus {
  color: #FFD700;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 分类统计 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
}

.category-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 28rpx;
  color: #333;
}

.category-points {
  font-size: 28rpx;
  font-weight: bold;
}

.category-points.plus { color: #52c41a; }
.category-points.minus { color: #ff4d4f; }

.category-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.category-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 8rpx;
}

/* 打卡记录 */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.record-left {
  display: flex;
  align-items: center;
}

.record-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.record-info {
  display: flex;
  flex-direction: column;
}

.record-name {
  font-size: 28rpx;
  color: #333;
}

.record-date {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.record-points {
  font-size: 32rpx;
  font-weight: bold;
}

.record-points.plus { color: #52c41a; }
.record-points.minus { color: #ff4d4f; }

.empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
}