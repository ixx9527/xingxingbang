/* pages/profile/profile.wxss */
.container { min-height: 100vh; background: #f5f5f5; }
.header-card { background: linear-gradient(135deg, #667eea, #764ba2); padding: 60rpx; text-align: center; color: #fff; }
.avatar { font-size: 100rpx; display: block; }
.nickname { font-size: 36rpx; font-weight: bold; display: block; margin-top: 20rpx; }
.section { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 30rpx; }
.section-title { font-size: 32rpx; font-weight: bold; margin-bottom: 20rpx; }
.child-list { display: flex; flex-direction: column; gap: 16rpx; }
.child-item { display: flex; align-items: center; padding: 20rpx; background: #f9f9f9; border-radius: 12rpx; }
.child-avatar { font-size: 60rpx; margin-right: 20rpx; }
.child-info { display: flex; flex-direction: column; }
.child-name { font-size: 30rpx; color: #333; }
.child-points { font-size: 24rpx; color: #999; margin-top: 6rpx; }
.child-add { text-align: center; padding: 30rpx; color: #667eea; border: 2rpx dashed #667eea; border-radius: 12rpx; margin-top: 16rpx; }
.menu-item { display: flex; align-items: center; padding: 30rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 40rpx; margin-right: 20rpx; }
.menu-text { flex: 1; font-size: 30rpx; }
.menu-arrow { color: #999; }
.logout-btn { margin: 40rpx 20rpx; padding: 30rpx; background: #fff; text-align: center; color: #ff4d4f; border-radius: 16rpx; }