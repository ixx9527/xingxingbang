<!--pages/profile/profile.wxml-->
<view class="container">
  <view class="header-card">
    <text class="avatar">👨‍👩‍👧</text>
    <text class="nickname">{{userInfo.nickname || '家长'}}</text>
  </view>

  <view class="section">
    <view class="section-title">孩子管理</view>
    <view class="child-list">
      <view class="child-item" wx:for="{{children}}" wx:key="id">
        <text class="child-avatar">👧</text>
        <view class="child-info">
          <text class="child-name">{{item.name}}</text>
          <text class="child-points">⭐ {{item.total_points}} 分 · 🔥 {{item.streak_days}}天</text>
        </view>
      </view>
      <view class="child-add" bindtap="goAddChild">+ 添加孩子</view>
    </view>
  </view>

  <view class="section">
    <view class="menu-item" bindtap="goAddChild">
      <text class="menu-icon">👶</text>
      <text class="menu-text">孩子管理</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goAddChild">
      <text class="menu-icon">🎁</text>
      <text class="menu-text">奖励管理</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="logout-btn" bindtap="logout">退出登录</view>
</view>