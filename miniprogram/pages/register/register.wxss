/* pages/register/register.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 80rpx 60rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-top: 10rpx;
}

.form {
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
}

.input-group {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.input {
  flex: 1;
  font-size: 30rpx;
}

.btn-register {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #333;
  font-weight: bold;
  font-size: 32rpx;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 40rpx;
  border: none;
}

.login-link {
  text-align: center;
  margin-top: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.login-link text {
  color: #667eea;
  margin-left: 10rpx;
}