/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* 头部卡片 */
.header-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  color: #fff;
  margin-bottom: 30rpx;
}

.child-selector {
  margin-bottom: 30rpx;
}

.picker {
  display: inline-flex;
  align-items: center;
  background: rgba(255,255,255,0.2);
  padding: 16rpx 30rpx;
  border-radius: 30rpx;
}

.child-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 10rpx;
}

.down-arrow {
  font-size: 24rpx;
  opacity: 0.8;
}

.score-summary {
  display: flex;
  justify-content: space-around;
}

.score-item {
  text-align: center;
}

.score-label {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
}

.score-value {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-top: 10rpx;
}

.score-value.plus {
  color: #FFD700;
}

/* 区块 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

/* 行为列表 */
.behavior-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.behavior-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.behavior-card.plus:active {
  background: #f0fff4;
}

.behavior-card.minus:active {
  background: #fff5f5;
}

.behavior-left {
  display: flex;
  align-items: center;
}

.behavior-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.behavior-name {
  font-size: 30rpx;
  color: #333;
}

.behavior-points {
  font-size: 32rpx;
  font-weight: bold;
}

.behavior-points.plus {
  color: #52c41a;
}

.behavior-points.minus {
  color: #ff4d4f;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
}

.action-icon {
  font-size: 48rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666;
  margin-top: 10rpx;
}