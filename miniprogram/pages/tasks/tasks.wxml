<!--pages/tasks/tasks.wxml-->
<view class="container">
  <view class="header">
    <text class="title">任务管理</text>
    <button class="add-btn" bindtap="goAdd">+ 添加</button>
  </view>

  <view class="category-tabs">
    <view 
      class="tab {{currentCategory == index ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="index"
      bindtap="onCategoryChange"
      data-index="{{index}}"
    >
      {{item}}
    </view>
  </view>

  <view class="task-list">
    <view class="task-item" wx:for="{{behaviors}}" wx:key="id">
      <view class="task-info">
        <text class="task-icon">{{item.icon}}</text>
        <view class="task-detail">
          <text class="task-name">{{item.name}}</text>
          <text class="task-meta">{{item.category}} · {{item.is_system ? '系统预设' : '自定义'}}</text>
        </view>
      </view>
      <view class="task-right">
        <text class="task-points {{item.points > 0 ? 'plus' : 'minus'}}">
          {{item.points > 0 ? '+' : ''}}{{item.points}}
        </text>
        <view class="task-actions" wx:if="{{!item.is_system}}">
          <text class="action-edit" bindtap="goEdit" data-id="{{item.id}}">编辑</text>
          <text class="action-delete" bindtap="onDelete" data-id="{{item.id}}">删除</text>
        </view>
      </view>
    </view>
  </view>
</view>