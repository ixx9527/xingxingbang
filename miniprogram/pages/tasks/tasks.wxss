/* pages/tasks/tasks.wxss */
.container { min-height: 100vh; background: #f5f5f5; padding: 20rpx; }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx; }
.title { font-size: 40rpx; font-weight: bold; }
.add-btn { background: #FFD700; color: #333; font-size: 28rpx; padding: 10rpx 30rpx; border-radius: 30rpx; }
.category-tabs { display: flex; gap: 20rpx; margin-bottom: 30rpx; overflow-x: auto; }
.tab { padding: 16rpx 30rpx; background: #fff; border-radius: 30rpx; font-size: 28rpx; color: #666; white-space: nowrap; }
.tab.active { background: #667eea; color: #fff; }
.task-list { display: flex; flex-direction: column; gap: 16rpx; }
.task-item { display: flex; justify-content: space-between; align-items: center; background: #fff; padding: 30rpx; border-radius: 16rpx; }
.task-info { display: flex; align-items: center; }
.task-icon { font-size: 48rpx; margin-right: 20rpx; }
.task-detail { display: flex; flex-direction: column; }
.task-name { font-size: 30rpx; color: #333; }
.task-meta { font-size: 24rpx; color: #999; margin-top: 6rpx; }
.task-right { text-align: right; }
.task-points { font-size: 32rpx; font-weight: bold; display: block; }
.task-points.plus { color: #52c41a; }
.task-points.minus { color: #ff4d4f; }
.task-actions { margin-top: 10rpx; }
.action-edit, .action-delete { font-size: 24rpx; margin-left: 20rpx; }
.action-edit { color: #667eea; }
.action-delete { color: #ff4d4f; }