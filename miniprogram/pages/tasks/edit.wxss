/* pages/tasks/edit.wxss */
.container { padding: 30rpx; background: #f5f5f5; min-height: 100vh; }
.form-item { background: #fff; padding: 30rpx; border-radius: 16rpx; margin-bottom: 20rpx; }
.label { font-size: 28rpx; color: #666; display: block; margin-bottom: 16rpx; }
.input { font-size: 30rpx; }
.points-ctrl { display: flex; align-items: center; justify-content: center; gap: 40rpx; }
.points-btn { width: 80rpx; height: 80rpx; font-size: 40rpx; background: #f5f5f5; border-radius: 50%; line-height: 80rpx; }
.points-value { font-size: 48rpx; font-weight: bold; width: 150rpx; text-align: center; }
.points-value.plus { color: #52c41a; }
.points-value.minus { color: #ff4d4f; }
.picker { font-size: 30rpx; padding: 10rpx 0; }
.icon-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.icon-item { width: 80rpx; height: 80rpx; font-size: 40rpx; text-align: center; line-height: 80rpx; background: #f5f5f5; border-radius: 12rpx; }
.icon-item.active { background: #667eea; }
.save-btn { background: linear-gradient(135deg, #FFD700, #FFA500); color: #333; font-weight: bold; margin-top: 40rpx; }