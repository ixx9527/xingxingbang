/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 120rpx 60rpx;
  box-sizing: border-box;
}

.logo {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 120rpx;
  display: block;
}

.logo-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-top: 20rpx;
}

.logo-sub {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-top: 10rpx;
}

.form {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2);
}

.input-group {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.input {
  flex: 1;
  font-size: 30rpx;
}

.btn-login {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #333;
  font-weight: bold;
  font-size: 32rpx;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 40rpx;
  border: none;
}

.register-link {
  text-align: center;
  margin-top: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.register-link text {
  color: #667eea;
  margin-left: 10rpx;
}