<!--pages/login/login.wxml-->
<view class="container">
  <view class="logo">
    <text class="logo-icon">⭐</text>
    <text class="logo-text">星星榜</text>
    <text class="logo-sub">儿童成长打卡系统</text>
  </view>

  <view class="form">
    <view class="input-group">
      <text class="input-icon">👤</text>
      <input 
        class="input" 
        placeholder="请输入用户名" 
        bindinput="onUsernameInput"
        value="{{username}}"
      />
    </view>

    <view class="input-group">
      <text class="input-icon">🔒</text>
      <input 
        class="input" 
        type="password" 
        placeholder="请输入密码" 
        bindinput="onPasswordInput"
        value="{{password}}"
      />
    </view>

    <button 
      class="btn-login" 
      bindtap="login" 
      loading="{{loading}}"
    >
      登 录
    </button>

    <view class="register-link">
      还没有账号？<text bindtap="goRegister">立即注册</text>
    </view>
  </view>
</view>